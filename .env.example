# Obrigatório em produção. Use uma string longa e aleatória (mínimo recomendado: 32 caracteres).
SESSION_SECRET=troque-por-uma-chave-longa-e-aleatoria

# O OAuth é opcional. Sem estas variáveis, o login por token continua funcionando.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# URL pública do projeto. Em desenvolvimento, pode ficar em branco.
APP_URL=http://localhost:3000

# Escopos do OAuth. "repo" permite gerenciar repositórios privados.
GITHUB_OAUTH_SCOPE=repo read:user

# Versão atual da API REST do GitHub.
GITHUB_API_VERSION=2026-03-10

PORT=3000

# Opcional: URL da API para GitHub Enterprise ou testes.
# GITHUB_API_URL=https://api.github.com
