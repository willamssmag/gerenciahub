{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/gerenciahub",
      "destination": "/gerenciahub/index.html"
    },
    {
      "source": "/gerenciahub/",
      "destination": "/gerenciahub/index.html"
    },
    {
      "source": "/html",
      "destination": "/html.html"
    }
  ]
}
